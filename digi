body {
    font-family: Arial, sans-serif;
    background-color: #f5f0ff;
    color: #2e1a47;
    margin: 0;
    line-height: 1.6;
}

header {
    background-color: #cfc3e8;
    padding: 20px;
}

header h1 {
    margin: 0;
}

header a {
    color: #2e1a47;
    text-decoration: none;
}

nav ul {
    list-style: none;
    padding: 0;
    margin-top: 15px;
}

nav li {
    margin-bottom: 10px;
}

main {
    padding: 20px;
    max-width: 1000px;
    margin: auto;
}

section {
    background-color: white;
    padding: 20px;
    margin-bottom: 20px;
    border-radius: 10px;
}

img {
    width: 100%;
    max-width: 250px;
    height: auto;
    border-radius: 10px;
}

input,
textarea {
    width: 100%;
    max-width: 400px;
    padding: 8px;
    box-sizing: border-box;
}

button {
    background-color: #a855f7;
    color: white;
    border: none;
    padding: 10px 15px;
    border-radius: 5px;
}

footer {
    background-color: #cfc3e8;
    padding: 20px;
    text-align: center;
}

@media (min-width: 768px) {
    nav ul {
        display: flex;
        gap: 20px;
    }

    nav li {
        margin-bottom: 0;
    }
}
